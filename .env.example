# Copy this file to .env and fill in the values before running docker-compose.
# .env is gitignored and must never be committed.

# PostgreSQL container
POSTGRES_DB=recipedb
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password

# Application datasource (must match the values above)
DB_URL=jdbc:postgresql://postgres:5432/recipedb
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# OpenAPI contact info
APP_CONTACT_NAME=Your Name
APP_CONTACT_EMAIL=your@email.com